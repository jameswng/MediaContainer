#!/bin/bash
# MediaContainer Environment-Clean Safe Wrapper
if [ -z "$MC_CLEANED" ]; then
    export MC_CLEANED=1
    exec env -i HOME="$HOME" USER="$USER" TERM="$TERM" PATH="$PATH" MC_CLEANED=1 "$0" "$@"
fi
python3 -c 'import sys; from pathlib import Path; ROOT = Path("/Volumes/real-home/local-home/iam/Work/ai/MediaContainer").resolve(); sys.path.insert(0, str(ROOT)); from mediacontainer.cli import main; main()' "$@"
