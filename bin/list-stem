#!/bin/bash
# MediaContainer Environment-Clean Safe Wrapper for list-stem
if [ -z "$MC_CLEANED" ]; then
    export MC_CLEANED=1
    exec env -i HOME="$HOME" USER="$USER" TERM="$TERM" PATH="$PATH" MC_CLEANED=1 "$0" "$@"
fi

python3 -c '
import sys
from pathlib import Path

# Add project root to sys.path
ROOT = Path("'$(pwd)'").resolve()
sys.path.insert(0, str(ROOT))

from mediacontainer.media_container import ClassifiedFile

def list_stems(paths):
    for p in paths:
        cf = ClassifiedFile.from_path(Path(p))
        print(f"{p}: {cf.stem}")

def main():
    args = sys.argv[1:]
    if not args:
        # Read from stdin
        paths = [line.strip() for line in sys.stdin if line.strip()]
        list_stems(paths)
    else:
        target = Path(args[0])
        if target.is_dir():
            paths = sorted(f.name for f in target.iterdir() if f.is_file())
            for p in paths:
                cf = ClassifiedFile.from_path(target / p)
                print(f"{p}: {cf.stem}")
        elif target.is_file():
            with open(target, "r") as f:
                paths = [line.strip() for line in f if line.strip()]
            list_stems(paths)
        else:
            # Assume it is a single file name or part of stdin if redirection was used but args[0] exists? 
            # Actually, the user said "list-stem dir", "list-stem file", "list-stem <".
            # If it is not a dir or file, maybe it is just a string?
            cf = ClassifiedFile.from_path(target)
            print(f"{target.name}: {cf.stem}")

if __name__ == "__main__":
    main()
' "$@"
